<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado seleccionado: aro negro con borde blanco interno -->
    <item android:state_checked="true">
        <layer-list>
            <!-- El aro negro exterior -->
            <item>
                <shape android:shape="oval">
                    <stroke android:width="4dp" android:color="@color/black" />
                </shape>
            </item>
            <!-- Un borde blanco interno para que el color resalte y no se pegue al negro -->
            <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
                <shape android:shape="oval">
                    <stroke android:width="2dp" android:color="@android:color/white" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Estado normal: borde gris muy sutil -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#30000000" />
        </shape>
    </item>
</selector>