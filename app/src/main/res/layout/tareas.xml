<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:background="#89CAB4">

    <!-- Título de la pantalla -->
    <TextView
        android:id="@+id/lbl_Titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="Actividades"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:textColor="@color/black"
        android:textStyle="bold" />


    <ImageView
        android:id="@+id/img_study"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_below="@id/lbl_Titulo"
        android:layout_marginTop="-53dp"
        android:contentDescription="@string/study_image_description"
        android:scaleType="centerInside"
        android:src="@drawable/study" />


    <LinearLayout
        android:id="@+id/toolbarIcons"
        android:layout_width="350dp"
        android:layout_height="70dp"
        android:layout_below="@+id/img_study"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:background="@drawable/verde_redondiado"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="25dp"
        android:paddingVertical="5dp">

        <Button
            android:id="@+id/btnInicio"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="🏠"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnCalendario"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📆"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnTareas"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_rounded"
            android:text="📄"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnKamba"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📋"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/toolDeTarea"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/toolbarIcons"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="2dp"
        android:background="@drawable/redendoverdeclaro"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <TextView
            android:id="@+id/lbl_ProximaClase"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:text="Asignaciones:"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAgrgar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/amarlloagregar"
            android:text="+"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            app:backgroundTint="@null" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/ContenedordeTodasTareas"
        android:layout_width="match_parent"
        android:layout_height="530dp"
        android:layout_below="@id/toolDeTarea"
        android:layout_marginTop="1dp"
        android:background="@drawable/button_rounded">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerActividades"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"/>

    </FrameLayout>

</RelativeLayout>
