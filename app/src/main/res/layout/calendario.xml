<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:background="#89CAB4">

    <TextView
        android:id="@+id/lbl_Titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="Calendario"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="30sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/img_study"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_below="@id/lbl_Titulo"
        android:layout_marginTop="-45dp"
        android:src="@drawable/study" />

    <LinearLayout
        android:id="@+id/toolbarIcons"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_below="@+id/img_study"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:background="@drawable/verde_redondiado"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <Button android:id="@+id/btnInicio" android:layout_width="0dp" android:layout_height="55dp" android:layout_margin="2dp" android:layout_weight="1" android:background="@drawable/blanco_redondiado" android:text="🏠" android:textSize="24sp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" app:backgroundTint="@null" />
        <Button android:id="@+id/btnCalendario" android:layout_width="0dp" android:layout_height="55dp" android:layout_margin="2dp" android:layout_weight="1" android:background="@drawable/blanco_redondiado" android:text="📆" android:textSize="24sp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" app:backgroundTint="@null" />
        <Button android:id="@+id/btnTareas" android:layout_width="0dp" android:layout_height="55dp" android:layout_margin="2dp" android:layout_weight="1" android:background="@drawable/blanco_redondiado" android:text="📄" android:textSize="24sp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" app:backgroundTint="@null" />
        <Button android:id="@+id/btnKamba" android:layout_width="0dp" android:layout_height="55dp" android:layout_margin="2dp" android:layout_weight="1" android:background="@drawable/blanco_redondiado" android:text="📋" android:textSize="24sp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" app:backgroundTint="@null" />
        <Button android:id="@+id/btnEventos" android:layout_width="0dp" android:layout_height="55dp" android:layout_margin="2dp" android:layout_weight="1" android:background="@drawable/button_rounded" android:text="🗓️" android:textSize="24sp" android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp" app:backgroundTint="@null" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutMes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/toolbarIcons"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">
        <Button android:id="@+id/btnMesAnterior" android:layout_width="40dp" android:layout_height="40dp" android:text="◀" android:background="@android:color/transparent" android:textColor="@color/black" android:textSize="20sp" />
        <TextView android:id="@+id/txtMesActual" android:layout_width="200dp" android:layout_height="wrap_content" android:text="Abril 2026" android:textAlignment="center" android:textColor="@color/black" android:textSize="20sp" android:textStyle="bold" />
        <Button android:id="@+id/btnMesSiguiente" android:layout_width="40dp" android:layout_height="40dp" android:text="▶" android:background="@android:color/transparent" android:textColor="@color/black" android:textSize="20sp" />
    </LinearLayout>

    <!-- CALENDARIO -->
    <FrameLayout
        android:id="@+id/ContenedorCalendario"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_below="@id/layoutMes"
        android:layout_marginTop="5dp"
        android:background="@drawable/button_rounded"
        android:padding="10dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCalendario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>

    <TextView
        android:id="@+id/lblTareasDia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ContenedorCalendario"
        android:layout_marginTop="10dp"
        android:text="Tareas del día:"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="16sp" />

    <!-- LISTA DE TAREAS DEL DÍA SELECCIONADO -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/lblTareasDia"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/blanco_redondiado">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTareasDia"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="5dp" />
    </FrameLayout>

</RelativeLayout>