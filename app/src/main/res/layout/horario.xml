<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:background="#89CABB">

    <!-- Título de la pantalla -->
    <TextView
        android:id="@+id/lbl_Titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="Horario"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:textColor="@color/black"
        android:textStyle="bold" />


    <ImageView
        android:id="@+id/img_study"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_below="@id/lbl_Titulo"
        android:layout_marginTop="-53dp"
        android:contentDescription="@string/study_image_description"
        android:scaleType="centerInside"
        android:src="@drawable/study" />


    <LinearLayout
        android:id="@+id/toolbarIcons"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_below="@+id/img_study"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:background="@drawable/verde_redondiado"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <Button
            android:id="@+id/btnInicio"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="🏠"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnCalendario"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/button_rounded"
            android:text="📆"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnTareas"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📄"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnKamba"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📋"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnEventos"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="🗓️"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/toolSemanda"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_below="@+id/toolbarIcons"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:background="@drawable/redendoverdeclaro"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingVertical="10dp">

        <Button
            android:id="@+id/btnLunes"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="L"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnMartes"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="M"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnMiercoles"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="M"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnJueves"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="J"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />


        <Button
            android:id="@+id/btnViernes"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="V"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnSabado"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="S"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnDomingo"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="D"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnAgrgar"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/amarlloagregar"
            android:text="+"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@null" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/ContenedoredeHorarios"
        android:layout_width="match_parent"
        android:layout_height="490dp"
        android:layout_below="@id/toolSemanda"
        android:layout_marginTop="10dp"
        android:background="@drawable/button_rounded">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMaterias"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:layout_gravity="center"/>

    </FrameLayout>

</RelativeLayout>