<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:background="#89CAB4">

    <!-- Título de la pantalla -->
    <TextView
        android:id="@+id/lbl_Titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="Inicio"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:textColor="@color/black"
        android:textStyle="bold" />


    <ImageView
        android:id="@+id/img_study"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_below="@id/lbl_Titulo"
        android:layout_marginTop="-53dp"
        android:contentDescription="@string/study_image_description"
        android:scaleType="centerInside"
        android:src="@drawable/study" />


    <LinearLayout
        android:id="@+id/toolbarIcons"
        android:layout_width="350dp"
        android:layout_height="70dp"
        android:layout_below="@+id/img_study"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:background="@drawable/verde_redondiado"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="25dp"
        android:paddingVertical="5dp">

        <Button
            android:id="@+id/btnInicio"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/button_rounded"
            android:text="🏠"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnCalendario"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📆"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnTareas"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📄"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnKamba"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📋"
            android:textColor="@color/black"
            android:textSize="22sp"
            app:backgroundTint="@null" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/contenerdebiendvdenida"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_below="@id/toolbarIcons"
        android:layout_marginTop="20dp"

        android:background="@drawable/button_rounded">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="start"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lbl_Bienvenida_Titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/bienvenida_titulo"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lbl_Bienvenida_Subtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="5dp"
                android:text="@string/bienvenida_subtitulo"
                android:textColor="@color/black"
                android:textSize="18sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/lbEentregas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/contenerdebiendvdenida"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="Proxima entrega:"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/contededordeTarea"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_below="@id/lbEentregas"
        android:layout_marginTop="10dp"
        android:background="@drawable/button_rounded">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTareas"
            android:layout_width="346dp"
            android:layout_height="166dp"
            android:layout_gravity="center" />

    </FrameLayout>

    <TextView
        android:id="@+id/lbl_ProximaClase"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/contededordeTarea"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="Proxima clase:"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/contededordeClases"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:layout_below="@id/lbl_ProximaClase"
        android:layout_marginTop="10dp"
        android:background="@drawable/button_rounded">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerClases"
            android:layout_width="330dp"
            android:layout_height="146dp"
            android:layout_gravity="center" />

    </FrameLayout>


</RelativeLayout>
