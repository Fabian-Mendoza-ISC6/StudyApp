<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:background="#89CAB4">

    <!-- Título de la pantalla -->
    <TextView
        android:id="@+id/lbl_Titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif"
        android:text="Inicio"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:textColor="@color/black"
        android:textStyle="bold" />


    <ImageView
        android:id="@+id/img_study"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_below="@id/lbl_Titulo"
        android:layout_marginTop="-53dp"
        android:contentDescription="@string/study_image_description"
        android:scaleType="centerInside"
        android:src="@drawable/logosinfondo" />

    <!-- Botón de configuración con fondo redondeado -->
    <Button
        android:id="@+id/btnConfiguracion"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="15dp"
        android:background="@drawable/blanco_redondiado"
        android:text="⚙️"
        android:textSize="24sp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        app:backgroundTint="@null" />

    <FrameLayout
        android:id="@+id/contenerdebiendvdenida"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_below="@id/img_study"
        android:layout_marginTop="20dp"
        android:background="@drawable/button_rounded">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lbl_Bienvenida_Titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bienvenida_titulo"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lbl_Bienvenida_Subtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/bienvenida_subtitulo"
                android:textColor="@color/black"
                android:textSize="18sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/contenerdebiendvdenida"
        android:layout_above="@+id/toolbarIcons"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lbEentregas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="Proxima entrega:"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/contededordeTarea"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/button_rounded">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerTareas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:layout_gravity="center" />

        </FrameLayout>

        <TextView
            android:id="@+id/lbl_ProximaClase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="Proxima clase:"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/contededordeClases"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="5dp"
            android:background="@drawable/button_rounded">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerClases"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:layout_gravity="center" />

        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/toolbarIcons"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="10dp"
        android:background="@drawable/verde_redondiado"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <Button
            android:id="@+id/btnInicio"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/button_rounded"
            android:text="🏠"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnCalendario"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📆"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnTareas"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📄"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnKamba"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="📋"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnEventos"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@drawable/blanco_redondiado"
            android:text="🗓️"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@null" />

    </LinearLayout>

</RelativeLayout>
